# stockmd-mini — local-only env. Copy to .env, then fill in.
# Never commit .env. The bootstrap generator does not put real values here.

# Next.js
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=stockmd-mini

# Supabase (local CLI defaults)
#
# NEXT_PUBLIC_SUPABASE_URL is browser-facing — point it at 127.0.0.1 so the
# browser running on the host can reach Supabase directly.
# SUPABASE_URL_SERVER is read by server-side handlers running in the app
# container; 127.0.0.1 from inside the container would point at the container
# itself, so it must be the host-reachable form (host.docker.internal).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_URL_SERVER=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme
SUPABASE_SERVICE_ROLE_KEY=changeme

# Database (local Supabase Postgres defaults)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
