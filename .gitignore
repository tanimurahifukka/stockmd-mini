# stockmd-mini — local-only files. Generated by agent-harness-bootstrap.

# Local env — never commit secrets
.env
.env.local
.env.*.local

# Stack-specific build/install output
node_modules/
.next/
dist/
build/
coverage/
.cache/

# Supabase local scratch dirs
supabase/.branches/
supabase/.temp/

# TypeScript incremental build cache
*.tsbuildinfo

# Python bytecode
__pycache__/
*.pyc
.pytest_cache/
.venv/

# Agent runtime — per-session, machine-local
.agent/runs/
.agent/events/*.jsonl
.agent/runtime/heartbeat.json
.agent/runtime/kill-switch

# Keep schemas, lessons, protected-files.json, sandbox-state.json, state.json
# under version control — they are part of the project's contract.
!.agent/schemas/
!.agent/lessons/
!.agent/protected-files.json
!.agent/runtime/sandbox-state.json
!.agent/runtime/state.json
!.agent/runtime/kill-switch.example

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
